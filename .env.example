# Copy this file to .env and fill in your key. .env is gitignored — never commit it.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-safeguard-20b

# Optional proxy for reaching OpenRouter (leave empty for a direct connection).
# Use socks5h:// to resolve DNS through the proxy (recommended for SOCKS5).
# Examples:
#   OPENROUTER_PROXY=socks5h://127.0.0.1:1080
#   OPENROUTER_PROXY=http://127.0.0.1:7890
OPENROUTER_PROXY=

# Rate-limit / retry (gpt-oss-safeguard-20b upstream via Groq may return HTTP 429)
OPENROUTER_MAX_RETRIES=6
OPENROUTER_RETRY_BASE_DELAY=5
OPENROUTER_RETRY_MAX_DELAY=120
OPENROUTER_REQUEST_DELAY=5
OPENROUTER_PARSE_RETRIES=2
